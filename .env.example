# Application URLs
PUBLIC_APP_URL=https://stockpro.example.com
GATEWAY_PUBLIC_BASE_URL=https://stockpro.example.com

# Database
DB_HOST=stockpro-db
DB_PORT=3306
DB_USER=stockpro
DB_PASSWORD=change-me

# Redis
REDIS_HOST=auth-redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# Kafka
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Eureka
EUREKA_HOST=eureka-server
EUREKA_PORT=8761
EUREKA_USER=eureka
EUREKA_PASSWORD=change-me
EUREKA_INSTANCE_HOSTNAME=localhost
EUREKA_PREFER_IP=false

# Admin Server
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# JWT
JWT_SECRET=replace-with-a-32-plus-character-secret
JWT_ACCESS_EXPIRY=28800000
JWT_REFRESH_EXPIRY=604800000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Mail / OTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-smtp-user
MAIL_PASS=your-smtp-password
MAIL_FROM=no-reply@example.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_DEV_LOG_OTP_ON_FAILURE=false
PASSWORD_RESET_OTP_LENGTH=6
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10

# Bootstrap Admin
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_NAME=StockPro Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# Payments
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
PAYMENT_MOCK_ENABLED=false
PAYMENT_KAFKA_ENABLED=true
PAYMENT_DUPLICATE_CLEANUP_ENABLED=true
